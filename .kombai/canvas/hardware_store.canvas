      "html": "\n<div class=\"bg-[#F5F5F5] text-[#111111] font-['IBM_Plex_Sans'] selection:bg-[#FF5800] selection:text-white\" data-kid=\"0\">\n    <style data-kid=\"1\">\n        @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap');\n        @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n        .font-space { font-family: 'Space Grotesk', sans-serif; }\n        \n        .brutalist-border {\n            border: 3px solid #111111;\n        }\n        \n        .film-strip-top {\n            background: repeating-linear-gradient(90deg, #111111, #111111 16px, transparent 16px, transparent 24px);\n            background-size: 40px 100%;\n        }\n        .sprocket-holes {\n            background: radial-gradient(circle, #333 30%, transparent 35%);\n            background-size: 30px 30px;\n        }\n\n        .diagonal-clip {\n            clip-path: polygon(20% 0, 100% 0, 100% 100%, 0% 100%);\n        }\n\n        .chat-bubble-left {\n            border-radius: 20px 20px 20px 4px;\n        }\n\n        .chat-bubble-right {\n            border-radius: 20px 20px 4px 20px;\n        }\n\n        ::-webkit-scrollbar {\n            width: 10px;\n        }\n        ::-webkit-scrollbar-track {\n            background: #111111;\n        }\n        ::-webkit-scrollbar-thumb {\n            background: #FF5800;\n        }\n    </style>\n\n    \n    <header class=\"bg-[#111111] text-white py-5 px-8 md:px-12 flex items-center justify-between border-b-[3px] border-[#111111] z-50 relative\" data-kid=\"2\">\n        <div class=\"flex items-center gap-10\" data-kid=\"3\">\n            <div class=\"flex items-center gap-2\" data-kid=\"4\">\n                <div class=\"w-10 h-10 bg-[#FF5800] flex items-center justify-center border-2 border-white rotate-3 group-hover:rotate-0 transition-transform\" data-kid=\"5\">\n                    <i class=