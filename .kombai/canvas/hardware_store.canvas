\"></i>\n                    </button>\n                    <button class=\"w-full text-left p-6 bg-[#F5F5F5] text-[#111111] brutalist-border font-bold uppercase text-sm flex items-center justify-between group hover:bg-[#111111] hover:text-white transition-all\" data-kid=\"303\">\n                        <span data-kid=\"304\">Payment Options</span>\n                        <i class=\"ti ti-chevron-right group-hover:translate-x-2 transition-transform\" data-kid=\"305\"></i>\n                    </button>\n                </div>\n\n                <div class=\"mt-8 p-10 border-[3px] border-dashed border-[#111111] bg-[#F5F5F5]\" data-kid=\"306\">\n                    <div class=\"flex items-center gap-4 mb-6\" data-kid=\"307\">\n                         <i class=\"ti ti-phone-call text-4xl text-[#FF5800]\" data-kid=\"308\"></i>\n                         <div data-kid=\"309\">\n                            <p class=\"text-[10px] font-bold uppercase text-gray-400\" data-kid=\"310\">Speak to Expert</p>\n                            <p class=\"text-xl font-bold font-space\" data-kid=\"311\">+1 (800) FORGE-PRO</p>\n                         </div>\n                    </div>\n                    <p class=\"text-xs text-gray-500 font-medium italic\" data-kid=\"312\">\"Available 24/7 for emergency machinery breakdown support.\"</p>\n                </div>\n            </div>\n\n            \n            <div class=\"col-span-12 md:col-span-8 space-y-12\" data-kid=\"313\">\n                \n                <div class=\"space-y-6\" data-kid=\"314\">\n                    <div class=\"brutalist-border bg-white p-8 group\" data-kid=\"315\">\n                        <div class=\"flex justify-between items-center cursor-pointer\" data-kid=\"316\">\n                            <h4 class=\"font-space text-xl font-bold uppercase tracking-tight\" data-kid=\"317\">How is heavy machinery delivery handled?</h4>\n                            <i class=\"ti ti-minus text-[#FF5800]\" data-kid=\"318\"></i>\n                        </div>\n                        <p class=\"mt-6 text-gray-600 leading-relaxed pl-6 border-l-4 border-[#FF5800]\" data-kid=\"319\">\n                            We utilize a specialized fleet of low-bed trailers for all heavy machinery transport. Our logistics team handles all state-line permits and escorts if required. Real-time GPS tracking is provided for every shipment above 2 tons.\n                        </p>\n                    </div>\n                    <div class=\"brutalist-border bg-[#F5F5F5] p-8 group hover:bg-white transition-colors\" data-kid=\"320\">\n                        <div class=\"flex justify-between items-center cursor-pointer\" data-kid=\"321\">\n                            <h4 class=\"font-space text-xl font-bold uppercase tracking-tight\" data-kid=\"322\">Do you offer on-field repair services?</h4>\n                            <i class=\"ti ti-plus text-[#111111]\" data-kid=\"323\"></i>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div class=\"bg-[#111111] brutalist-border p-12 text-white shadow-[16px_16px_0px_0px_#FF5800]\" data-kid=\"324\">\n                    <div class=\"flex items-end justify-between mb-10\" data-kid=\"325\">\n                        <div data-kid=\"326\">\n                            <h3 class=\"font-space text-4xl font-bold uppercase tracking-tighter\" data-kid=\"327\">Bulk Order Request</h3>\n                            <p class=\"text-gray-500 mt-2 text-xs font-bold uppercase tracking-widest\" data-kid=\"328\">Get Custom Commercial Pricing</p>\n                        </div>\n                        <div class=\"px-4 py-1.5 border border-gray-800 text-[10px] font-bold uppercase tracking-widest text-gray-400\" data-kid=\"329\">Secure Inquiry</div>\n                    </div>\n\n                    <form class=\"grid grid-cols-1 md:grid-cols-2 gap-8\" data-kid=\"330\">\n                        <div class=\"space-y-2\" data-kid=\"331\">\n                            <label class=\"text-[10px] font-bold uppercase tracking-widest text-gray-400\" data-kid=\"332\">Full Name</label>\n                            <input type=\"text\" class=\"w-full bg-[#1a1a1a] border-b-2 border-gray-800 focus:border-[#FF5800] py-4 px-0 text-white outline-none transition-all\" placeholder=\"Enter name...\" data-kid=\"333\">\n                        </div>\n                        <div class=\"space-y-2\" data-kid=\"334\">\n                            <label class=\"text-[10px] font-bold uppercase tracking-widest text-gray-400\" data-kid=\"335\">Email Address</label>\n                            <input type=\"email\" class=\"w-full bg-[#1a1a1a] border-b-2 border-gray-800 focus:border-[#FF5800] py-4 px-0 text-white outline-none transition-all\" placeholder=\"company@mail.com\" data-kid=\"336\">\n                        </div>\n                        <div class=\"col-span-1 md:col-span-2 space-y-2\" data-kid=\"337\">\n                            <label class=\"text-[10px] font-bold uppercase tracking-widest text-gray-400\" data-kid=\"338\">Project Requirements</label>\n                            <textarea rows=\"4\" class=\"w-full bg-[#1a1a1a] border-b-2 border-gray-800 focus:border-[#FF5800] py-4 px-0 text-white outline-none transition-all resize-none\" placeholder=\"Describe the machinery models and quantities required...\" data-kid=\"339\"></textarea>\n                        </div>\n                        <div class=\"col-span-1 md:col-span-2 flex justify-end pt-4\" data-kid=\"340\">\n                            <button class=\"bg-[#FF5800] text-[#111111] px-12 py-5 font-bold uppercase text-sm brutalist-border hover:bg-white hover:-translate-y-1 transition-all\" data-kid=\"341\">Submit Quotation Request</button>\n                        </div>\n                    </form>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-0 border-t-[3px] border-[#111111]\" data-kid=\"342\">\n        <div class=\"grid grid-cols-1 md:grid-cols-4 h-auto md:h-[450px]\" data-kid=\"343\">\n            \n            <div class=\"p-12 bg-white border-r-[3px] border-[#111111] flex flex-col justify-center\" data-kid=\"344\">\n                <i class=\"ti ti-clock text-4xl text-[#FF5800] mb-8\" data-kid=\"345\"></i>\n                <h4 class=\"font-space text-2xl font-bold uppercase tracking-tighter mb-6\" data-kid=\"346\">Business Hours</h4>\n                <div class=\"space-y-3 text-sm font-bold uppercase tracking-widest\" data-kid=\"347\">\n                    <div class=\"flex justify-between text-gray-400\" data-kid=\"348\"><span data-kid=\"349\">MON — FRI</span> <span class=\"text-[#111111]\" data-kid=\"350\">08:00 - 20:00</span></div>\n                    <div class=\"flex justify-between text-gray-400\" data-kid=\"351\"><span data-kid=\"352\">SATURDAY</span> <span class=\"text-[#111111]\" data-kid=\"353\">09:00 - 18:00</span></div>\n                    <div class=\"flex justify-between text-gray-400\" data-kid=\"354\"><span data-kid=\"355\">SUNDAY</span> <span class=\"text-red-500\" data-kid=\"356\">CLOSED</span></div>\n                </div>\n            </div>\n\n            \n            <div class=\"relative bg-[#111111] border-r-[3px] border-[#111111] overflow-hidden\" data-kid=\"357\">\n                <img src=\"https://images.unsplash.com/photo-1565647952915-9644fcd446a4?auto=format&w=800&q=80&fit=crop\" class=\"w-full h-full object-cover grayscale opacity-80\" decoding=\"async\" loading=\"lazy\" data-kid=\"358\">\n                <div class=\"absolute inset-0 flex flex-col items-center justify-center p-8 bg-[#111111]/10 hover:bg-transparent transition-all cursor-pointer\" data-kid=\"359\">\n                    <div class=\"w-16 h-16 bg-[#FF5800] brutalist-border flex items-center justify-center mb-4\" data-kid=\"360\">\n                        <i class=\"ti ti-map-pin text-2xl text-[#111111]\" data-kid=\"361\"></i>\n                    </div>\n                    <button class=\"bg-[#111111] text-white px-6 py-2 font-bold uppercase text-[10px]\" data-kid=\"362\">Open Interactive Map</button>\n                </div>\n            </div>\n\n            \n            <div class=\"p-12 bg-[#FF5800] border-r-[3px] border-[#111111] flex flex-col justify-center group cursor-pointer hover:bg-white transition-colors\" data-kid=\"363\">\n                <i class=\"ti ti-alert-triangle text-4xl text-[#111111] mb-8 group-hover:animate-bounce\" data-kid=\"364\"></i>\n                <h4 class=\"font-space text-2xl font-bold uppercase tracking-tighter mb-4\" data-kid=\"365\">Emergency Contact</h4>\n                <p class=\"text-xs font-bold uppercase tracking-widest text-[#111111]/60 mb-8\" data-kid=\"366\">Direct line for critical machinery failure in field.</p>\n                <span class=\"font-space text-3xl font-bold text-[#111111]\" data-kid=\"367\">+1 (800) BREAK-FIX</span>\n            </div>\n\n            \n            <div class=\"p-12 bg-white flex flex-col justify-center\" data-kid=\"368\">\n                <i class=\"ti ti-building-airport text-4xl text-[#FF5800] mb-8\" data-kid=\"369\"></i>\n                <h4 class=\"font-space text-2xl font-bold uppercase tracking-tighter mb-6\" data-kid=\"370\">Central Hub</h4>\n                <address class=\"not-italic text-sm font-bold uppercase tracking-widest text-gray-400 leading-loose\" data-kid=\"371\">\n                    Forge Industrial Park, Plot 89<br data-kid=\"372\">\n                    Agricultural District West<br data-kid=\"373\">\n                    Chandigarh, CH 160001<br data-kid=\"374\">\n                    <span class=\"text-[#FF5800] mt-4 block\" data-kid=\"375\">info@industrialforge.com</span>\n                </address>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"bg-[#111111] text-white pt-24 pb-12 px-8 md:px-12 border-t-[3px] border-[#111111]\" data-kid=\"376\">\n        <div class=\"grid grid-cols-1 md:grid-cols-4 gap-16 mb-24\" data-kid=\"377\">\n            <div class=\"col-span-1\" data-kid=\"378\">\n                <div class=\"flex items-center gap-2 mb-8\" data-kid=\"379\">\n                    <div class=\"w-10 h-10 bg-[#FF5800] flex items-center justify-center border-2 border-white\" data-kid=\"380\">\n                        <i class=\"ti ti-tools text-xl text-[#111111]\" data-kid=\"381\"></i>\n                    </div>\n                    <span class=\"font-space text-2xl font-bold tracking-tighter uppercase leading-none\" data-kid=\"382\">Industrial Forge</span>\n                </div>\n                <p class=\"text-xs text-gray-500 leading-loose mb-8\" data-kid=\"383\">Building the tools that feed nations. Our commitment to industrial excellence spans over a decade of innovation in the agricultural sector.</p>\n                <div class=\"flex gap-4\" data-kid=\"384\">\n                    <a href=\"#\" class=\"w-10 h-10 border border-gray-800 flex items-center justify-center hover:bg-[#FF5800] hover:text-[#111111] transition-all\" data-kid=\"385\"><i class=\"ti ti-brand-facebook\" data-kid=\"386\"></i></a>\n                    <a href=\"#\" class=\"w-10 h-10 border border-gray-800 flex items-center justify-center hover:bg-[#FF5800] hover:text-[#111111] transition-all\" data-kid=\"387\"><i class=\"ti ti-brand-instagram\" data-kid=\"388\"></i></a>\n                    <a href=\"#\" class=\"w-10 h-10 border border-gray-800 flex items-center justify-center hover:bg-[#FF5800] hover:text-[#111111] transition-all\" data-kid=\"389\"><i class=\"ti ti-brand-youtube\" data-kid=\"390\"></i></a>\n                </div>\n            </div>\n\n            <div class=\"space-y-8\" data-kid=\"391\">\n                <h5 class=\"text-[10px] font-bold uppercase tracking-[0.4em] text-[#FF5800]\" data-kid=\"392\">Product Lines</h5>\n                <ul class=\"space-y-4 text-sm font-bold uppercase tracking-widest text-gray-500\" data-kid=\"393\">\n                    <li data-kid=\"394\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"395\">Heavy Machinery</a></li>\n                    <li data-kid=\"396\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"397\">Irrigation Systems</a></li>\n                    <li data-kid=\"398\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"399\">Industrial Tools</a></li>\n                    <li data-kid=\"400\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"401\">Spare Parts</a></li>\n                </ul>\n            </div>\n\n            <div class=\"space-y-8\" data-kid=\"402\">\n                <h5 class=\"text-[10px] font-bold uppercase tracking-[0.4em] text-[#FF5800]\" data-kid=\"403\">Services</h5>\n                <ul class=\"space-y-4 text-sm font-bold uppercase tracking-widest text-gray-500\" data-kid=\"404\">\n                    <li data-kid=\"405\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"406\">Machinery Repair</a></li>\n                    <li data-kid=\"407\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"408\">Logistics Support</a></li>\n                    <li data-kid=\"409\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"410\">Custom Fabrication</a></li>\n                    <li data-kid=\"411\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"412\">Field Maintenance</a></li>\n                </ul>\n            </div>\n\n            <div class=\"space-y-8\" data-kid=\"413\">\n                <h5 class=\"text-[10px] font-bold uppercase tracking-[0.4em] text-[#FF5800]\" data-kid=\"414\">Company</h5>\n                <ul class=\"space-y-4 text-sm font-bold uppercase tracking-widest text-gray-500\" data-kid=\"415\">\n                    <li data-kid=\"416\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"417\">About Forge</a></li>\n                    <li data-kid=\"418\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"419\">Client Testimonials</a></li>\n                    <li data-kid=\"420\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"421\">Partner Network</a></li>\n                    <li data-kid=\"422\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"423\">Contact Support</a></li>\n                </ul>\n            </div>\n        </div>\n\n        <div class=\"pt-12 border-t border-gray-900 flex flex-col md:flex-row justify-between items-center gap-6\" data-kid=\"424\">\n            <span class=\"text-[10px] font-bold uppercase tracking-widest text-gray-700\" data-kid=\"425\">© 2024 Industrial Forge & Farm. All Industrial Rights Reserved.</span>\n            <div class=\"flex gap-8 text-[10px] font-bold uppercase tracking-widest text-gray-700\" data-kid=\"426\">\n                <a href=\"#\" class=\"hover:text-white\" data-kid=\"427\">Privacy Protocol</a>\n                <a href=\"#\" class=\"hover:text-white\" data-kid=\"428\">Terms of Supply</a>\n                <a href=\"#\" class=\"hover:text-white\" data-kid=\"429\">Accessibility</a>\n            </div>\n        </div>\n    </footer>\n\n    \n    <div class=\"absolute bottom-[450px] left-1/2 -translate-x-1/2 z-[100] px-4\" data-kid=\"430\">\n        <div class=\"bg-white/80 backdrop-blur-2xl rounded-2xl border-[3px] border-[#111111] shadow-2xl p-2 flex items-center gap-2\" data-kid=\"431\">\n            <button class=\"w-14 h-14 bg-[#25D366] text-white rounded-xl flex items-center justify-center hover:scale-110 transition-transform brutalist-border border-none group relative\" data-kid=\"432\">\n                <i class=\"ti ti-brand-whatsapp text-2xl\" data-kid=\"433\"></i>\n                <span class=\"absolute -top-12 left-1/2 -translate-x-1/2 bg-[#111111] text-white text-[10px] px-3 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none uppercase font-bold whitespace-nowrap\" data-kid=\"434\">WhatsApp</span>\n            </button>\n            <button class=\"w-14 h-14 bg-[#111111] text-white rounded-xl flex items-center justify-center hover:scale-110 transition-transform brutalist-border border-none group relative\" data-kid=\"435\">\n                <i class=\"ti ti-terminal text-2xl\" data-kid=\"436\"></i>\n                <span class=\"absolute -top-12 left-1/2 -translate-x-1/2 bg-[#111111] text-white text-[10px] px-3 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none uppercase font-bold whitespace-nowrap\" data-kid=\"437\">AI Support</span>\n            </button>\n            <div class=\"w-[2px] h-8 bg-gray-300 mx-1\" data-kid=\"438\"></div>\n            <button class=\"w-14 h-14 bg-white text-[#111111] rounded-xl flex items-center justify-center hover:scale-110 transition-transform brutalist-border border-none group relative\" data-kid=\"439\">\n                <i class=\"ti ti-search text-2xl\" data-kid=\"440\"></i>\n                <span class=\"absolute -top-12 left-1/2 -translate-x-1/2 bg-[#111111] text-white text-[10px] px-3 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none uppercase font-bold whitespace-nowrap\" data-kid=\"441\">Global Search</span>\n            </button>\n            <button class=\"bg-[#FF5800] text-[#111111] px-6 py-4 rounded-xl font-bold uppercase text-xs hover:scale-105 transition-transform brutalist-border border-none ml-1\" data-kid=\"442\">\n                Book Visit\n            </button>\n        </div>\n    </div>\n</div>\n",
