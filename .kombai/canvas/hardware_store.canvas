nter border-r border-[var(--color-coffee)]/5\" data-kid=\"178\">\n                    <span class=\"text-[var(--color-coffee)]/5 font-serif-display italic text-6xl select-none\" data-kid=\"179\">Est. 2014</span>\n                </div>\n\n                <div class=\"bg-[var(--color-linen)] flex items-center justify-center\" data-kid=\"180\">\n                    <i class=\"ti ti-seeding text-5xl text-[var(--color-copper)]/10\" data-kid=\"181\"></i>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-40 px-12 lg:px-24 bg-[var(--color-linen)]\" data-kid=\"182\">\n        <div class=\"max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-24 items-center\" data-kid=\"183\">\n            <div class=\"lg:col-span-7\" data-kid=\"184\">\n                <span class=\"text-[var(--color-copper)] uppercase tracking-[0.4em] text-[10px] font-black mb-8 block\" data-kid=\"185\">Craftsmanship</span>\n                <h2 class=\"text-7xl font-serif-display text-[var(--color-coffee)] mb-12 leading-tight\" data-kid=\"186\">Mastery in <br data-kid=\"187\"><span class=\"italic\" data-kid=\"188\">Maintenance</span></h2>\n                <div class=\"space-y-8 font-serif-body text-xl text-[var(--color-coffee)]/70 max-w-2xl leading-relaxed\" data-kid=\"189\">\n                    <p data-kid=\"190\">Our dedication to quality doesn't end at the sale. The Editorial Harvest workshop is staffed by generational mechanics who understand the pulse of your machinery.</p>\n                    <p data-kid=\"191\">From precision calibration of irrigation pumps to complete restoration of heritage tractors, we ensure your tools remain as sharp as the day they were forged.</p>\n                </div>\n                <div class=\"mt-16 flex items-center gap-12\" data-kid=\"192\">\n                    <button class=\"bg-[var(--color-coffee)] text-white px-12 py-5 uppercase tracking-[0.3em] text-[10px] font-bold hover:bg-[var(--color-olive)] transition-all\" data-kid=\"193\">Book Service</button>\n                    <div class=\"flex items-center gap-4 group cursor-pointer\" data-kid=\"194\">\n                        <div class=\"w-12 h-12 rounded-full border border-[var(--color-coffee)]/10 flex items-center justify-center group-hover:bg-[var(--color-copper)] group-hover:text-white transition-all\" data-kid=\"195\">\n                            <i class=\"ti ti-player-play\" data-kid=\"196\"></i>\n                        </div>\n                        <span class=\"text-[10px] uppercase tracking-widest font-black\" data-kid=\"197\">Watch Workshop Tour</span>\n                    </div>\n                </div>\n            </div>\n            \n            <div class=\"lg:col-span-5\" data-kid=\"198\">\n                <div class=\"bg-white p-12 simple-elevation border-t-8 border-[var(--color-olive)] relative\" data-kid=\"199\">\n                    <div class=\"absolute -top-10 -left-10 w-24 h-24 bg-[var(--color-copper)] opacity-10 rounded-full\" data-kid=\"200\"></div>\n                    <h3 class=\"text-3xl font-serif-display text-[var(--color-coffee)] mb-8\" data-kid=\"201\">Service Portfolio</h3>\n                    <ul class=\"space-y-6\" data-kid=\"202\">\n                        <li class=\"flex items-start gap-4 group\" data-kid=\"203\">\n                            <div class=\"w-10 h-10 bg-[var(--color-linen)] flex items-center justify-center group-hover:bg-[var(--color-olive)]/10 transition-colors\" data-kid=\"204\">\n                                <i class=\"ti ti-settings text-[var(--color-olive)]\" data-kid=\"205\"></i>\n                            </div>\n                            <div data-kid=\"206\">\n                                <h4 class=\"text-sm font-bold uppercase tracking-widest text-[var(--color-coffee)]\" data-kid=\"207\">Engine Calibration</h4>\n                                <p class=\"text-xs text-[var(--color-coffee)]/50 mt-1\" data-kid=\"208\">Full diagnostics and 