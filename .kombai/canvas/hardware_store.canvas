=\"296\">\n        \n        <div class=\"bg-white p-10 rounded-[3rem] shadow-xl hover:-translate-y-2 transition-all h-full flex flex-col\" data-kid=\"297\">\n          <div class=\"flex items-center gap-4 mb-8\" data-kid=\"298\">\n            <img src=\"https://images.unsplash.com/photo-1626029322280-ba48ba381345?auto=format&w=100&q=80&fit=crop\" class=\"w-14 h-14 rounded-full object-cover border-2 border-[var(--emerald)]\" alt=\"User\" data-kid=\"299\">\n            <div data-kid=\"300\">\n              <h5 class=\"font-black text-[var(--evergreen)]\" data-kid=\"301\">Rajesh Deshmukh</h5>\n              <div class=\"flex text-[var(--amber)] text-xs\" data-kid=\"302\">\n                <i class=\"ti ti-star-filled\" data-kid=\"303\"></i><i class=\"ti ti-star-filled\" data-kid=\"304\"></i><i class=\"ti ti-star-filled\" data-kid=\"305\"></i><i class=\"ti ti-star-filled\" data-kid=\"306\"></i><i class=\"ti ti-star-filled\" data-kid=\"307\"></i>\n              </div>\n            </div>\n          </div>\n          <p class=\"text-gray-600 italic leading-relaxed font-medium\" data-kid=\"308\">\"The transition to solar pumps was effortless thanks to their support. My electricity bills are now zero! <img src=\"https://cdn.jsdelivr.net/npm/openmoji-named-svgs@latest/color/folded-hands.svg\" class=\"inline w-6 h-6 ml-1\" data-kid=\"309\">\"</p>\n        </div>\n\n        \n        <div class=\"bg-[var(--evergreen)] p-10 rounded-[3rem] text-white shadow-2xl h-full flex flex-col\" data-kid=\"310\">\n          <div class=\"flex items-center gap-4 mb-8\" data-kid=\"311\">\n             <img src=\"https://images.unsplash.com/photo-1696371269777-88d1ce71642c?auto=format&w=100&q=80&fit=crop\" class=\"w-14 h-14 rounded-full object-cover border-2 border-[var(--emerald)]\" alt=\"User\" data-kid=\"312\">\n            <div data-kid=\"313\">\n              <h5 class=\"font-black\" data-kid=\"314\">Kuldeep Singh</h5>\n              <div class=\"flex text-[var(--amber)] text-xs\" data-kid=\"315\">\n                <i class=\"ti ti-star-filled\" data-kid=\"316\"></i><i class=\"ti ti-star-filled\" data-kid=\"317\"></i><i class=\"ti ti-star-filled\" data-kid=\"318\"></i><i class=\"ti ti-star-filled\" data-kid=\"319\"></i><i class=\"ti ti-star-filled\" data-kid=\"320\"></i>\n              </div>\n            </div>\n          </div>\n          <p class=\"text-white/80 italic leading-relaxed font-medium\" data-kid=\"321\">\"Best customer service in the state. They actually care about the farmer's yield, not just making a sale.\"</p>\n        </div>\n\n        \n        <div class=\"bg-white p-10 rounded-[3rem] shadow-xl hover:-translate-y-2 transition-all h-full flex flex-col\" data-kid=\"322\">\n          <div class=\"flex items-center gap-4 mb-8\" data-kid=\"323\">\n             <img src=\"https://images.unsplash.com/photo-1607892408220-c80c0f8651d0?auto=format&w=100&q=80&fit=crop\" class=\"w-14 h-14 rounded-full object-cover border-2 border-[var(--emerald)]\" alt=\"User\" data-kid=\"324\">\n            <div data-kid=\"325\">\n              <h5 class=\"font-black text-[var(--evergreen)]\" data-kid=\"326\">Amita Patel</h5>\n              <div class=\"flex text-[var(--amber)] text-xs\" data-kid=\"327\">\n                <i class=\"ti ti-star-filled\" data-kid=\"328\"></i><i class=\"ti ti-star-filled\" data-kid=\"329\"></i><i class=\"ti ti-star-filled\" data-kid=\"330\"></i><i class=\"ti ti-star-filled\" data-kid=\"331\"></i><i class=\"ti ti-star-filled\" data-kid=\"332\"></i>\n              </div>\n            </div>\n          </div>\n          <p class=\"text-gray-600 italic leading-relaxed font-medium\" data-kid=\"333\">\"The hardware quality is outstanding. My power tools have survived three heavy monsoons without a speck of rust.\"</p>\n        </div>\n\n        \n        <div class=\"bg-[var(--emerald)] p-10 rounded-[3rem] text-[var(--evergreen)] shadow-xl h-full flex flex-col\" data-kid=\"334\">\n           <div class=\"flex items-center gap-4 mb-8\" data-kid=\"335\">\n             <img src=\"https://images.unsplash.com/photo-1521140714186-512186ea3d3b?auto=format&w=100&q=80&fit=crop\" class=\"w-14 h-14 rounded-full object-cover border-2 border-[var(--evergreen)]\" alt=\"User\" data-kid=\"336\">\n            <div data-kid=\"337\">\n              <h5 class=\"font-black\" data-kid=\"338\">Vijay Rathore</h5>\n              <div class=\"flex text-white text-xs\" data-kid=\"339\">\n                <i class=\"ti ti-star-filled\" data-kid=\"340\"></i><i class=\"ti ti-star-filled\" data-kid=\"341\"></i><i class=\"ti ti-star-filled\" data-kid=\"342\"></i><i class=\"ti ti-star-filled\" data-kid=\"343\"></i><i class=\"ti ti-star-half\" data-kid=\"344\"></i>\n              </div>\n            </div>\n          </div>\n          <p class=\"font-black italic leading-relaxed\" data-kid=\"345\">\"Their AI assistant correctly recommended the drip system for my sloping terrain. Smart engineering at its best!\"</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"bg-[var(--evergreen)] py-32 px-8 overflow-hidden\" data-kid=\"346\">\n    <div class=\"max-w-7xl mx-auto space-y-16\" data-kid=\"347\">\n      <div class=\"flex items-center justify-between\" data-kid=\"348\">\n        <h2 class=\"text-5xl font-black font-heading text-white\" data-kid=\"349\">Hub in Action</h2>\n        <div class=\"flex gap-4\" data-kid=\"350\">\n          <button class=\"w-16 h-16 rounded-full glass flex items-center justify-center text-white hover:bg-white hover:text-[var(--evergreen)] transition-all\" data-kid=\"351\">\n            <i class=\"ti ti-chevron-left text-2xl\" data-kid=\"352\"></i>\n          </button>\n          <button class=\"w-16 h-16 rounded-full glass flex items-center justify-center text-white hover:bg-white hover:text-[var(--evergreen)] transition-all\" data-kid=\"353\">\n            <i class=\"ti ti-chevron-right text-2xl\" data-kid=\"354\"></i>\n          </button>\n        </div>\n      </di