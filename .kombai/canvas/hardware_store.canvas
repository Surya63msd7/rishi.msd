fee)]/60 leading-relaxed font-serif-body hidden group-hover:block transition-all\" data-kid=\"262\">\n                            Absolutely. Our team of certified technicians is available for on-field consultation and repair services within a 100-mile radius of our flagship stores.\n                        </p>\n                    </div>\n                    \n                    <div class=\"border-b border-[var(--color-coffee)]/10 pb-8 group cursor-pointer\" data-kid=\"263\">\n                        <div class=\"flex justify-between items-center text-left\" data-kid=\"264\">\n                            <span class=\"text-xl font-serif-display text-[var(--color-coffee)] group-hover:text-[var(--color-copper)] transition-colors\" data-kid=\"265\">What is the return policy for agricultural tools?</span>\n                            <i class=\"ti ti-plus text-[var(--color-olive)] group-hover:rotate-45 transition-transform duration-500\" data-kid=\"266\"></i>\n                        </div>\n                        <p class=\"mt-6 text-[15px] text-[var(--color-coffee)]/60 leading-relaxed font-serif-body hidden group-hover:block transition-all\" data-kid=\"267\">\n                            We offer a 30-day no-questions-asked return policy for unused tools in their original packaging. Machinery returns are subject to a standard inspection.\n                        </p>\n                    </div>\n                    \n                    <div class=\"border-b border-[var(--color-coffee)]/10 pb-8 group cursor-pointer\" data-kid=\"268\">\n                        <div class=\"flex justify-between items-center text-left\" data-kid=\"269\">\n                            <span class=\"text-xl font-serif-display text-[var(--color-coffee)] group-hover:text-[var(--color-copper)] transition-colors\" data-kid=\"270\">How can I apply for a wholesale agricultural account?</span>\n                            <i class=\"ti ti-plus text-[var(--color-olive)] group-hover:rotate-45 transition-transform duration-500\" data-kid=\"271\"></i>\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"mt-16 p-8 bg-[var(--color-olive)]/5 border-l-4 border-[var(--color-olive)]\" data-kid=\"272\">\n                    <h4 class=\"text-sm font-black uppercase tracking-widest text-[var(--color-olive)] mb-4\" data-kid=\"273\">Emergency Contact</h4>\n                    <p class=\"text-sm text-[var(--color-coffee)]/70 italic mb-4\" data-kid=\"274\">Need urgent machinery repair or support for critical farm operations?</p>\n                    <a href=\"tel:+15551234567\" class=\"text-xl font-serif-display text-[var(--color-coffee)] font-bold\" data-kid=\"275\">+1 (555) 123-4567</a>\n                </div>\n            </div>\n            \n            \n            <div class=\"bg-white p-16 shadow-[0_40px_100px_-20px_rgba(61,43,31,0.1)] border border-[var(--color-coffee)]/5 relative\" data-kid=\"276\">\n                <div class=\"absolute -top-6 -right-6 w-12 h-12 bg-[var(--color-copper)] flex items-center justify-center text-white shadow-lg\" data-kid=\"277\">\n                    <i class=\"ti ti-mail text-xl\" data-kid=\"278\"></i>\n                </div>\n                <h3 class=\"text-4xl font-serif-display text-[var(--color-coffee)] mb-4\" data-kid=\"279\">Bulk Procurement</h3>\n                <p class=\"text-sm text-[var(--color-coffee)]/50 mb-12 font-serif-body\" data-kid=\"280\">Submit your requirements for a customized commercial quotation.</p>\n                \n                <form class=\"space-y-10\" data-kid=\"281\">\n                    <div class=\"grid grid-cols-2 gap-10\" data-kid=\"282\">\n                        <div class=\"space-y-3\" data-kid=\"283\">\n                            <label class=\"text-xs uppercase tracking-[0.2em] font-bold text-[var(--color-coffee)]/40\" data-kid=\"284\">Full Name</label>\n                            <input type=\"text\" class=\"w-full border-b border-[var(--color-coffee)]/10 py-3 focus:outline-hidden focus:border-[var(--color-olive)] transition-colors text-base font-serif-body bg-transparent\" data-kid=\"285\">\n                        </div>\n                        <div class=\"space-y-3\" data-kid=\"286\">\n                            <label class=\"text-xs uppercase tracking-[0.2em] font-bold text-[var(--color-coffee)]/40\" data-kid=\"287\">Email Address</label>\n                            <input type=\"email\" class=\"w-full border-b border-[var(--color-coffee)]/10 py-3 focus:outline-hidden focus:border-[var(--color-olive)] transition-colors text-base font-serif-body bg-transparent\" data-kid=\"288\">\n                        </div>\n                    </div>\n                    \n                    <div class=\"space-y-3\" data-kid=\"289\">\n                        <label class=\"text-xs uppercase tracking-[0.2em] font-bold text-[var(--color-coffee)]/40\" data-kid=\"290\">Product Category</label>\n                        <select class=\"w-full border-b border-[var(--color-coffee)]/10 py-3 focus:outline-hidden focus:border-[var(--color-olive)] transition-colors text-base font-serif-body appearance-none bg-transparent\" data-kid=\"291\">\n                            <option data-kid=\"292\">Irrigation & Pump Systems</option>\n                            <option data-kid=\"293\">Hand & Power Tools</option>\n                            <option data-kid=\"294\">Heavy Agricultural Machinery</option>\n                            <option data-kid=\"295\">Precision Farm Sensors</option>\n                        </select>\n                    </div>\n                    \n                    <div class=\"space-y-3\" data-kid=\"296\">\n                        <label class=\"text-[9px] uppercase tracking-[0.4em] font-black text-[var(--color-coffee)]/40\" data-kid=\"297\">Inquiry Details</label>\n                        <textarea rows=\"5\" placeholder=\"Tell us about your requirements...\" class=\"w-full border border-[var(--color-coffee)]/10 p-4 focus:outline-hidden focus:border-[var(--color-olive)] transition-colors text-base font-serif-body bg-[var(--color-linen)]/10 resize-none\" data-kid=\"298\"></textarea>\n                    </div>\n                    \n                    <button class=\"w-full bg-[var(--color-coffee)] text-white py-6 uppercase tracking-[0.4em] text-[10px] font-black hover:bg-[var(--color-olive)] transition-all simple-elevation\" data-kid=\"299\">\n                        Request Quote\n                    </button>\n                    \n                    <p class=\"text-center text-[9px] text-[var(--color-coffee)]/30 uppercase tracking-widest italic\" data-kid=\"300\">\n                        Responses are typically provided within 24 business hours.\n                    </p>\n                </form>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-20 px-12 lg:px-24\" data-kid=\"301\">\n        <div class=\"max-w-7xl mx-auto\" data-kid=\"302\">\n            <div class=\"bg-[var(--color-olive)] text-white py-5 px-12 flex justify-between items-center simple-elevation\" data-kid=\"303\">\n                <span class=\"text-[10px] font-black uppercase tracking-[0.4em]\" data-kid=\"304\">Global Flagship Store</span>\n                <a href=\"#\" class=\"text-[10px] font-black uppercase tracking-[0.4em] flex items-center gap-3 hover:gap-5 transition-all\" data-kid=\"305\">Get Navigation Directions <i class=\"ti ti-arrow-right\" data-kid=\"306\"></i></a>\n            </div>\n            \n            <div class=\"grid grid-cols-1 lg:grid-cols-2 h-[600px] border border-[var(--color-coffee)]/5\" data-kid=\"307\">\n                <div class=\"bg-white p-20 flex flex-col justify-center\" data-kid=\"308\">\n                    <div class=\"grid grid-cols-2 gap-16\" data-kid=\"309\">\n                        <div data-kid=\"310\">\n                            <h4 class=\"text-xs uppercase tracking-[0.2em] font-bold text-[var(--color-coffee)]/30 mb-8 flex items-center gap-2\" data-kid=\"311\">\n                                <i class=\"ti ti-clock text-sm text-[var(--color-copper)]\" data-kid=\"312\"></i> Operating Hours\n                            </h4>\n                            <ul class=\"space-y-6 text-sm text-[var(--color-coffee)] font-serif-body\" data-kid=\"313\">\n                                <li class=\"flex justify-between border-b border-[var(--color-coffee)]/5 pb-3\" data-kid=\"314\"><span data-kid=\"315\">Mon - Fri</span> <span class=\"font-bold\" data-kid=\"316\">08:00 - 19:00</span></li>\n                                <li class=\"flex justify-between border-b border-[var(--color-coffee)]/5 pb-3\" data-kid=\"317\"><span data-kid=\"318\">Saturday</span> <span class=\"font-bold\" data-kid=\"319\">09:00 - 17:00</span></li>\n                                <li class=\"flex justify-between pb-3\" data-kid=\"320\"><span data-kid=\"321\">Sunday</span> <span class=\"text-[var(--color-copper)] font-black uppercase tracking-widest text-[10px]\" data-kid=\"322\">Closed</span></li>\n                            </ul>\n                        </div>\n                        <div data-kid=\"323\">\n                            <h4 class=\"text-[9px] uppercase tracking-[0.4em] font-black text-[var(--color-coffee)]/30 mb-8 flex items-center gap-2\" data-kid=\"324\">\n                                <i class=\"ti ti-map-pin text-sm text-[var(--color-copper)]\" data-kid=\"325\"></i> Store Location\n                            </h4>\n                            <div class=\"text-lg font-serif-display text-[var(--color-coffee)] mb-8 leading-snug\" data-kid=\"326\">\n                                124 Harvest Lane,<br data-kid=\"327\">\n                                Green Valley, AG 50231<br data-kid=\"328\">\n                                United Agricultural District\n                            </div>\n                            <div class=\"space-y-2\" data-kid=\"329\">\n                                <a href=\"mailto:hello@editorialharvest.com\" class=\"text-sm text-[var(--color-olive)] hover:text-[var(--color-copper)] transition-colors block font-serif-body\" data-kid=\"330\">hello@editorialharvest.com</a>\n                                <div class=\"text-sm font-bold text-[var(--color-coffee)] font-serif-body\" data-kid=\"331\">+1 (555) 890-4567</div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                \n                <div class=\"relative bg-[var(--color-linen)] overflow-hidden group\" data-kid=\"332\">\n                    <img src=\"https://images.pexels.com/photos/31981968/pexels-photo-31981968.jpeg?auto=compress&cs=tinysrgb&w=1200&q=80\" class=\"w-full h-full object-cover grayscale contrast-125 opacity-40 group-hover:scale-110 transition-transform duration-[20s]\" data-kid=\"333\">\n                    <div class=\"absolute inset-0 bg-[var(--color-olive)]/5\" data-kid=\"334\"></div>\n                    \n                    <div class=\"absolute inset-0 flex items-center justify-center\" data-kid=\"335\">\n                        <div class=\"relative\" data-kid=\"336\">\n                            <div class=\"w-16 h-16 bg-[var(--color-copper)]/30 rounded-full animate-ping absolute -inset-0\" data-kid=\"337\"></div>\n                            <div class=\"w-6 h-6 bg-[var(--color-copper)] rounded-full relative z-10 shadow-2xl flex items-center justify-center border-2 border-white\" data-kid=\"338\">\n                                <div class=\"w-1.5 h-1.5 bg-white rounded-full\" data-kid=\"339\"></div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer class=\"bg-[var(--color-linen)] border-t border-[var(--color-coffee)]/10 pt-32 pb-24 px-12 lg:px-24\" data-kid=\"340\">\n        <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-12\" data-kid=\"341\">\n            <div class=\"flex flex-col gap-4\" data-kid=\"342\">\n                <div class=\"text-3xl font-serif-display italic tracking-tighter text-[var(--color-coffee)]\" data-kid=\"343\">\n                    Editorial <span class=\"font-normal not-italic text-[var(--color-olive)]\" data-kid=\"344\">Harvest</span>\n                </div>\n                <p class=\"text-[9px] uppercase tracking-[0.3em] font-black text-[var(--color-coffee)]/30\" data-kid=\"345\">Premium Agricultural Purveyors</p>\n            </div>\n            \n            <div class=\"flex flex-wrap justify-center gap-x-12 gap-y-4 text-[10px] uppercase tracking-[0.3em] font-bold text-[var(--color-coffee)]/60\" data-kid=\"346\">\n                <a href=\"#\" class=\"hover:text-[var(--color-copper)] transition-colors\" data-kid=\"347\">Privacy</a>\n                <a href=\"#\" class=\"hover:text-[var(--color-copper)] transition-colors\" data-kid=\"348\">Terms</a>\n                <a href=\"#\" class=\"hover:text-[var(--color-copper)] transition-colors\" data-kid=\"349\">Shipping</a>\n                <a href=\"#\" class=\"hover:text-[var(--color-copper)] transition-colors\" data-kid=\"350\">Cookies</a>\n                <a href=\"#\" class=\"hover:text-[var(--color-copper)] transition-colors\" data-kid=\"351\">Sitemap</a>\n            </div>\n            \n            <div class=\"flex gap-6\" data-kid=\"352\">\n                <a href=\"#\" class=\"w-10 h-10 rounded-full border border-[var(--color-coffee)]/10 flex items-center justify-center hover:bg-[var(--color-copper)] hover:text-white transition-all\" data-kid=\"353\"><i class=\"ti ti-brand-instagram\" data-kid=\"354\"></i></a>\n                <a href=\"#\" class=\"w-10 h-10 rounded-full border border-[var(--color-coffee)]/10 flex items-center justify-center hover:bg-[var(--color-copper)] hover:text-white transition-all\" data-kid=\"355\"><i class=\"ti ti-brand-facebook\" data-kid=\"356\"></i></a>\n                <a href=\"#\" class=\"w-10 h-10 rounded-full border border-[var(--color-coffee)]/10 flex items-center justify-center hover:bg-[var(--color-copper)] hover:text-white transition-all\" data-kid=\"357\"><i class=\"ti ti-brand-youtube\" data-kid=\"358\"></i></a>\n            </div>\n        </div>\n        \n        <div class=\"max-w-7xl mx-auto mt-16 pt-8 border-t border-[var(--color-coffee)]/5 flex flex-col md:flex-row justify-between items-center gap-6\" data-kid=\"359\">\n            <div class=\"text-[9px] uppercase tracking-[0.4em] font-black text-[var(--color-coffee)]/30\" data-kid=\"360\">\n                © 2024 Editorial Harvest. Crafted for Quality.\n            </div>\n            <div class=\"flex items-center gap-4 text-[9px] uppercase tracking-widest text-[var(--color-coffee)]/40 font-bold\" data-kid=\"361\">\n                <span data-kid=\"362\">Designed by Premium Studios</span>\n                <div class=\"w-1 h-1 bg-[var(--color-coffee)]/20 rounded-full\" data-kid=\"363\"></div>\n                <span data-kid=\"364\">Curated for Growth</span>\n            </div>\n        </div>\n    </footer>\n\n    \n    <div class=\"absolute bottom-24 left-1/2 -translate-x-1/2 z-[100]\" data-kid=\"365\">\n        <div class=\"flex items-center glass px-10 py-6 rounded-full shadow-[0_50px_100px_-20px_rgba(61,43,31,0.4)] gap-10 border border-white/60 whitespace-nowrap\" data-kid=\"366\">\n            <button class=\"flex items-center gap-3 text-[10px] uppercase tracking-[0.3em] font-black text-[var(--color-coffee)] hover:text-[var(--color-copper)] transition-colors cursor-pointer group\" data-kid=\"367\">\n                <div class=\"w-8 h-8 rounded-full bg-[var(--color-coffee)]/5 flex items-center justify-center group-hover:bg-[var(--color-copper)] group-hover:text-white transition-all\" data-kid=\"368\">\n                    <i class=\"ti ti-message-dots text-lg\" data-kid=\"369\"></i>\n                </div>\n                <span data-kid=\"370\">AI Concierge</span>\n            </button>\n            <div class=\"w-[1px] h-6 bg-[var(--color-coffee)]/10\" data-kid=\"371\"></div>\n            <button class=\"flex items-center gap-3 text-[10px] uppercase tracking-[0.3em] font-black text-[var(--color-coffee)] hover:text-[var(--color-copper)] transition-colors cursor-pointer group\" data-kid=\"372\">\n                <div class=\"w-8 h-8 rounded-full bg-[var(--color-coffee)]/5 flex items-center justify-center group-hover:bg-emerald-600 group-hover:text-white transition-all\" data-kid=\"373\">\n                    <i class=\"ti ti-brand-whatsapp text-lg\" data-kid=\"374\"></i>\n                </div>\n                <span data-kid=\"375\">WhatsApp Support</span>\n            </button>\n        </div>\n    </div>\n\n</div>\n\n\n",
