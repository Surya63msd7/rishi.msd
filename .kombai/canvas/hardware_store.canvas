      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Figtree:wght@300;400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --evergreen: #013220;\n    --ivory: #FFF8E7;\n    --emerald: #50C878;\n    --amber: #FACA16;\n  }\n\n  body {\n    font-family: 'Figtree', sans-serif;\n    background-color: var(--evergreen);\n    color: white;\n    margin: 0;\n  }\n\n  .font-heading {\n    font-family: 'Plus Jakarta Sans', sans-serif;\n  }\n\n  .glass {\n    background: rgba(255, 255, 255, 0.08);\n    backdrop-filter: blur(20px) saturate(180%);\n    -webkit-backdrop-filter: blur(20px) saturate(180%);\n    border: 1px solid rgba(255, 255, 255, 0.15);\n  }\n\n  .glass-dark {\n    background: rgba(1, 50, 32, 0.8);\n    backdrop-filter: blur(16px);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n  }\n\n  .glass-ivory {\n    background: rgba(255, 248, 231, 0.9);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(1, 50, 32, 0.08);\n  }\n\n  .glow-emerald {\n    box-shadow: 0 0 40px -10px rgba(80, 200, 120, 0.3);\n  }\n\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n\n  .animate-marquee {\n    display: flex;\n    width: 200%;\n    animation: marquee 20s linear infinite;\n  }\n\n  .animate-marquee:hover {\n    animation-play-state: paused;\n  }\n\n  .stagger-up {\n    animation: staggerUp 0.6s ease-out forwards;\n  }\n\n  @keyframes staggerUp {\n    from { opacity: 0; transform: translateY(30px); }\n    to { opacity: 1; transform: translateY(0); }\n  }\n\n  .float-leaf {\n    animation: floatLeaf 6s ease-in-out infinite;\n  }\n\n  @keyframes floatLeaf {\n    0%, 100% { transform: translateY(0) rotate(0deg); }\n    50% { transform: translateY(-15px) rotate(10deg); }\n  }\n</style>\n\n<div class=\"relative overflow-hidden\" data-kid=\"1\">\n  \n  <nav class=\"absolute top-0 left-0 right-0 z-[100] px-8 py-5 transition-all duration-300\" data-kid=\"2\">\n    <div class=\"max-w-7xl mx-auto flex items-center justify-between glass px-8 py-4 rounded-full border-white/20 shadow-2xl\" data-kid=\"3\">\n      <div class=\"flex items-center gap-3\" data-kid=\"4\">\n        <div class=\"w-10 h-10 bg-[var(--emerald)] rounded-xl flex items-center justify-center shadow-lg shadow-[var(--emerald)]/20\" data-kid=\"5\">\n          <i class=\"ti ti-leaf text-white text-2xl\" data-kid=\"6\"></i>\n        </div>\n        <span class=\"text-2xl font-black font-heading tracking-tight text-white\" data-kid=\"7\">Solar<span class=\"text-[var(--emerald)]\" data-kid=\"8\">Hub</span></span>\n      </div>\n      \n      <div class=\"hidden lg:flex items-center gap-10 text-white/80 font-semibold tracking-wide text-sm\" data-kid=\"9\">\n        <a href=\"#\" class=\"hover:text-[var(--emerald)] transition-colors\" data-kid=\"10\">HOME</a>\n        <a href=\"#\" class=\"hover:text-[var(--emerald)] transition-colors\" data-kid=\"11\">SHOP</a>\n        <a href=\"#\" class=\"hover:text-[var(--emerald)] transition-colors\" data-kid=\"12\">SERVICES</a>\n        <a href=\"#\" class=\"hover:text-[var(--emerald)] transition-colors\" data-kid=\"13\">ABOUT</a>\n      </div>\n\n      <div class=\"flex items-center gap-5\" data-kid=\"14\">\n        <div class=\"hidden sm:flex items-center bg-white/10 rounded-full p-1 border border-white/10\" data-kid=\"15\">\n          <button class=\"px-5 py-1.5 rounded-full bg-[var(--emerald)] text-white text-xs font-bold shadow-sm\" data-kid=\"16\">EN</button>\n          <button class=\"px-5 py-1.5 rounded-full text-white/60 text-xs font-bold hover:text-white transition-colors\" data-kid=\"17\">HI</button>\n        </div>\n        <button class=\"text-white hover:text-[var(--emerald)] transition-colors\" data-kid=\"18\">\n          <i class=\"ti ti-search text-2xl\" data-kid=\"19\"></i>\n        </button>\n        <button class=\"px-8 py-2.5 bg-[var(--emerald)] text-white rounded-full font-bold text-sm shadow-xl shadow-[var(--emerald)]/20 hover:scale-105 active:scale-95 transition-all\" data-kid=\"20\">\n          LOG IN\n        </button>\n      </div>\n    </div>\n  </nav>\n\n  \n  <section class=\"relative h-[850px] flex items-center justify-center\" data-kid=\"21\">\n    <video src=\"https://videos.pexels.com/video-files/6685779/6685779-hd_1920_1080_30fps.mp4\" poster=\"https://images.pexels.com/videos/6685779/pexels-photo-6685779.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"absolute inset-0 w-full h-full object-cover\" data-kid=\"22\"></video>\n    <div class=\"absolute inset-0 bg-gradient-to-b from-[var(--evergreen)]/70 via-transparent to-[var(--evergreen)] z-10\" data-kid=\"23\"></div>\n    \n    <div class=\"relative z-20 max-w-5xl px-4 text-center\" data-kid=\"24\">\n      <div class=\"glass p-12 md:p-20 rounded-[4rem] border-white/20 shadow-3xl space-y-10 animate-in fade-in zoom-in duration-1000\" data-kid=\"25\">\n        <div class=\"inline-flex items-center gap-3 px-6 py-2 rounded-full bg-[var(--amber)]/20 border border-[var(--amber)]/30 text-[var(--amber)] text-xs font-bold uppercase tracking-[0.2em]\" data-kid=\"26\">\n          <span class=\"flex h-2 w-2 rounded-full bg-[var(--amber)] animate-pulse\" data-kid=\"27\"></span>\n          Revolutionizing Agriculture\n        </div>\n        \n        <h1 class=\"text-6xl md:text-8xl font-black font-heading text-white leading-[1.1] drop-shadow-[0_10px_30px_rgba(0,0,0,0.5)]\" data-kid=\"28\">\n          Premium Tools for <br data-kid=\"29\"> <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-[var(--emerald)] to-[var(--amber)]\" data-kid=\"30\">Modern Yields</span>\n        </h1>\n        \n        <p class=\"text-lg md:text-xl text-white/70 max-w-2xl mx-auto leading-relaxed font-medium\" data-kid=\"31\">\n          The ultimate Solarpunk Hardware Hub. Empowering sustainable growth with high-performance machinery and eco-friendly technology.\n        </p>\n\n        <div class=\"relative max-w-3xl mx-auto group\" data-kid=\"32\">\n          <div class=\"absolute -inset-1 bg-gradient-to-r from-[var(--emerald)] to-[var(--amber)] rounded-full blur opacity-25 group-hover:opacity-60 transition duration-700\" data-kid=\"33\"></div>\n          <div class=\"relative flex items-center bg-white rounded-full p-2.5 shadow-2xl\" data-kid=\"34\">\n            <div class=\"pl-8 text-gray-400\" data-kid=\"35\">\n              <i class=\"ti ti-search text-2xl\" data-kid=\"36\"></i>\n            </div>\n            <input type=\"text\" placeholder=\"Search tractors, solar pumps, hardware...\" class=\"flex-1 px-5 py-4 bg-transparent outline-none text-gray-800 text-lg placeholder:text-gray-400 font-medium\" data-kid=\"37\">\n            <button class=\"p-4 text-gray-400 hover:text-[var(--emerald)] transition-colors border-r border-gray-100 mr-3\" data-kid=\"38\">\n              <i class=\"ti ti-microphone text-2xl\" data-kid=\"39\"></i>\n            </button>\n            <button class=\"px-10 py-4 bg-[var(--evergreen)] text-white rounded-full font-bold text-lg hover:bg-[var(--emerald)] transition-all shadow-lg active:scale-95\" data-kid=\"40\">\n              SEARCH\n            </button>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"relative z-30 -mt-20 px-8\" data-kid=\"41\">\n    <div class=\"max-w-7xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6\" data-kid=\"42\">\n      <div class=\"bg-white p-10 rounded-[3rem] shadow-3xl flex items-center gap-6 border border-white group hover:border-[var(--emerald)] transition-all duration-500\" data-kid=\"43\">\n        <div class=\"w-16 h-16 bg-[var(--emerald)]/10 text-[var(--emerald)] rounded-2xl flex items-center justify-center text-3xl group-hover:scale-110 transition-transform\" data-kid=\"44\">\n      