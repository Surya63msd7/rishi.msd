utton>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-40 px-12 lg:px-24 overflow-hidden bg-white/20\" data-kid=\"235\">\n        <div class=\"max-w-7xl mx-auto relative h-[850px] photo-scatter\" data-kid=\"236\">\n            \n            <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-center z-50 pointer-events-none\" data-kid=\"237\">\n                <h2 class=\"text-9xl font-serif-display text-[var(--color-coffee)] italic mb-4 drop-shadow-[0_2px_10px_rgba(250,240,230,0.8)]\" data-kid=\"238\">The Gallery</h2>\n                <p class=\"text-[10px] uppercase tracking-[0.6em] font-black text-[var(--color-copper)] drop-shadow-sm\" data-kid=\"239\">Life at Editorial Harvest</p>\n            </div>\n\n            \n            <div class=\"absolute top-0 left-0 w-1/4 aspect-square bg-white p-4 shadow-2xl rotate-[-6deg] z-10\" data-kid=\"240\">\n                <img src=\"https://images.unsplash.com/photo-1778870708651-836cb75725d4?auto=format&w=800&q=80&fit=crop\" class=\"w-full h-full object-cover grayscale-[0.3]\" data-kid=\"241\">\n            </div>\n            <div class=\"absolute top-10 right-10 w-1/5 aspect-[4/5] bg-white p-4 shadow-2xl rotate-[8deg] z-20\" data-kid=\"242\">\n                <img src=\"https://images.unsplash.com/photo-1576226170186-74644779ccd6?auto=format&w=800&q=80&fit=crop\" class=\"w-full h-full object-cover grayscale-[0.3]\" data-kid=\"243\">\n            </div>\n            <div class=\"absolute bottom-20 left-1/4 w-1/3 aspect-video bg-white p-5 shadow-2xl rotate-[3deg] z-30\" data-kid=\"244\">\n                <img src=\"https://images.unsplash.com/photo-1729454854315-4bd98d945f7e?auto=format&w=1200&q=80&fit=crop\" class=\"w-full h-full object-cover grayscale-[0.3]\" data-kid=\"245\">\n            </div>\n            <div class=\"absolute top-1/3 right-1/4 w-1/5 aspect-square bg-white p-4 shadow-2xl rotate-[-12deg] z-40\" data-kid=\"246\">\n                <img src=