er:-translate-y-1 transition-all active:translate-x-0 active:translate-y-0 shadow-[4px_4px_0px_0px_#ffffff] hover:shadow-none\" data-kid=\"20\">\n                Request Quote\n            </button>\n        </div>\n    </header>\n\n    \n    <section class=\"relative w-full h-[780px] flex overflow-hidden border-b-[3px] border-[#111111]\" data-kid=\"21\">\n        \n        <div class=\"w-full md:w-1/2 bg-white flex flex-col justify-center px-8 md:px-24 z-10 relative\" data-kid=\"22\">\n            <div class=\"max-w-xl\" data-kid=\"23\">\n                <div class=\"flex items-center gap-4 mb-8\" data-kid=\"24\">\n                    <span class=\"bg-[#111111] text-white text-[10px] font-bold uppercase tracking-[0.4em] px-3 py-1.5\" data-kid=\"25\">Premium Standard</span>\n                    <div class=\"h-[2px] w-16 bg-[#FF5800]\" data-kid=\"26\"></div>\n                </div>\n                <h1 class=\"font-space text-7xl md:text-8xl font-bold text-[#111111] leading-[0.85] tracking-tighter mb-10 uppercase\" data-kid=\"27\">\n                    Industrial <br data-kid=\"28\"> <span class=\"text-[#FF5800]\" data-kid=\"29\">Steel &</span> <br data-kid=\"30\"> Flame\n                </h1>\n                <p class=\"text-[#111111]/70 text-lg mb-12 max-w-md font-medium border-l-4 border-[#91A3B0] pl-8 leading-relaxed\" data-kid=\"31\">\n                    Heavy-duty agricultural machinery and professional hardware designed for the rigorous demands of modern farming infrastructure.\n                </p>\n                \n                \n                <div class=\"relative max-w-lg group\" data-kid=\"32\">\n                    <div class=\"absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none\" data-kid=\"33\">\n                        <i class=\"ti ti-search text-gray-400 text-xl\" data-kid=\"34\"></i>\n                    </div>\n                    <input type=\"text\" placeholder=\"Search machinery or parts model...\" class=\"w-full bg-[#F5F5F5] brutalist-border py-5 pl-14 pr-32 font-bold focus:outline-none focus:bg-white transition-all placeholder:text-gray-400 text-lg\" data-kid=\"35\">\n                    <button class=\"absolute right-2 top-2 bottom-2 bg-[#111111] text-white px-8 font-bold uppercase text-xs hover:bg-[#FF5800] transition-colors brutalist-border border-none\" data-kid=\"36\">\n                        Search\n                    </button>\n                </div>\n                \n                <div class=\"mt-8 flex gap-6 text-[10px] font-bold uppercase tracking-widest text-gray-400\" data-kid=\"37\">\n                    <span class=\"flex items-center gap-2\" data-kid=\"38\"><i class=\"ti ti-check text-[#FF5800]\" data-kid=\"39\"></i> Global Shipping</span>\n                    <span class=\"flex items-center gap-2\" data-kid=\"40\"><i class=\"ti ti-check text-[#FF5800]\" data-kid=\"41\"></i> OEM Certified</span>\n                    <span class=\"flex items-center gap-2\" data-kid=\"42\"><i class=\"ti ti-check text-[#FF5800]\" data-kid=\"43\"></i> 24/7 Support</span>\n                </div>\n            </div>\n        </div>\n\n        \n        <div class=\"absolute top-0 right-0 w-[60%] h-full z-0 overflow-hidden hidden md:block\" data-kid=\"44\">\n            <div class=\"w-full h-full bg-[#111111] relative diagonal-clip\" data-kid=\"45\">\n                <img src=\"https://images.unsplash.com/photo-1614977645540-7abd88ba8e56?auto=format&w=1400&q=80&fit=crop\" alt=\"Heavy Agricultural Machinery\" class=\"w-full h-full object-cover grayscale-[30%] brightness-[0.8] hover:grayscale-0 hover:brightness-100 transition-all duration-1000 scale-105\" decoding=\"async\" loading=\"lazy\" data-kid=\"46\">\n                <div class=\"absolute inset-0 bg-gradient-to-r from-[#111111]/60 to-transparent\" data-kid=\"47\"></div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"px-8 md:px-12 py-16 -mt-12 relative z-20\" data-kid=\"48\">\n        <div class=\"grid grid-cols-1 md:grid-cols-3 gap-0 brutalist-border bg-white shadow-[12px_12px_0px_0px_#111111]\" data-kid=\"49\">\n            <div class=\"p-10 border-b md:border-b-0 md:border-r-[3px] border-[#111111] flex flex-col justify-center items-center text-center group hover:bg-[#F5F5F5] transition-colors\" data-kid=\"50\">\n                <span class=\"font-space text-6xl font-bold text-[#111111] mb-2\" data-kid=\"51\">10+</span>\n                <span class=\"text-sm font-bold uppercase tracking-widest text-[#FF5800]\" data-kid=\"52\">Years of Service</span>\n                <p class=\"text-xs text-gray-400 mt-4 max-w-[200px]\" data-kid=\"53\">Established reliability in the farming and construction sectors since 2014.</p>\n            </div>\n            <div class=\"p-10 border-b md:border-b-0 md:border-r-[3px] border-[#111111] bg-[#111111] flex flex-col justify-center items-center text-center relative overflow-hidden\" data-kid=\"54\">\n                <div class=\"absolute top-0 right-0 p-4 opacity-10\" data-kid=\"55\">\n                    <i class=\"ti ti-star-filled text-6xl text-white\" data-kid=\"56\"></i>\n                </div>\n                <span class=\"font-space text-6xl font-bold text-white mb-2 relative z-10\" data-kid=\"57\">98%</span>\n                <span class=\"text-sm font-bold uppercase tracking-widest text-[#FF5800] relative z-10\" data-kid=\"58\">Satisfaction Rate</span>\n                <p class=\"text-xs text-gray-500 mt-4 max-w-[200px] relative z-10\" data-kid=\"59\">Over 5,000 farmers and contractors trust us for their heavy machinery needs.</p>\n            </div>\n            <div class=\"p-10 flex flex-col justify-center items-center text-center group hover:bg-[#F5F5F5] transition-colors\" data-kid=\"60\">\n                <span class=\"font-space text-6xl font-bold text-[#111111] mb-2\" data-kid=\"61\">10k+</span>\n                <span class=\"text-sm font-bold uppercase tracking-widest text-[#FF5800]\" data-kid=\"62\">Parts Available</span>\n                <p class=\"text-xs text-gray-400 mt-4 max-w-[200px]\" data-kid=\"63\">Extensive inventory of tools, components, and replacement machinery parts.</p>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-12 bg-white border-y-[3px] border-[#111111] overflow-hidden\" data-kid=\"64\">\n        <div class=\"px-12 mb-6 flex items-center justify-between\" data-kid=\"65\">\n            <span class=\"text-[10px] font-bold uppercase tracking-[0.3em] text-gray-400\" data-kid=\"66\">Authorized Dealer & Technical Partner</span>\n            <div class=\"flex-grow mx-8 h-[1px] bg-gray-200\" data-kid=\"67\"></div>\n        </div>\n        <div class=\"flex items-center justify-around gap-12 px-12 opacity-80 grayscale hover:grayscale-0 hover:opacity-100 transition-all\" data-kid=\"68\">\n            <div class=\"flex flex-col items-center\" data-kid=\"69\">\n                <span class=\"font-space font-bold text-2xl uppercase tracking-tighter\" data-kid=\"70\">DEERE TECH</span>\n                <span class=\"text-[8px] font-mono\" data-kid=\"71\">SPEC: HEAVY-DIV-01</span>\n            </div>\n            <div class=\"flex flex-col items-center\" data-kid=\"72\">\n                <span class=\"font-space font-bold text-2xl uppercase tracking-tighter\" data-kid=\"73\">CAT SYSTEM</span>\n                <span class=\"text-[8px] font-mono\" data-kid=\"74\">SPEC: PWR-IND-A9</span>\n            </div>\n            <div class=\"flex flex-col items-center\" data-kid=\"75\">\n                <span class=\"font-space font-bold text-2xl uppercase tracking-tighter\" data-kid=\"76\">KUBOTA PRO</span>\n                <span class=\"text-[8px] font-mono\" data-kid=\"77\">SPEC: IRRI-CTRL-X</span>\n            </div>\n            <div class=\"flex flex-col items-center\" data-kid=\"78\">\n                <span class=\"font-space font-bold text-2xl uppercase tracking-tighter\" data-kid=\"79\">MAKITA IND</span>\n                <span class=\"text-[8px] font-mono\" data-kid=\"80\">SPEC: TOOL-PRO-V8</span>\n            </div>\n            <div class=\"flex flex-col items-center\" data-kid=\"81\">\n                <span class=\"font-space font-bold text-2xl uppercase tracking-tighter\" data-kid=\"82\">CASE IH</span>\n                <span class=\"text-[8px] font-mono\" data-kid=\"83\">SPEC: HARV-UNIT-Y</span>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-24 px-8 md:px-12\" data-kid=\"84\">\n        <div class=\"flex items-end justify-between mb-12\" data-kid=\"85\">\n            <div data-kid=\"86\">\n                <span class=\"text-[10px] font-bold uppercase tracking-[0.4em] text-[#FF5800] mb-2 block\" data-kid=\"87\">Stock Updates</span>\n                <h2 class=\"font-space text-6xl font-bold uppercase tracking-tighter leading-none mb-2\" data-kid=\"88\">Seasonal <span class=\"text-[#FF5800]\" data-kid=\"89\">&</span> <br data-kid=\"90\"> Arrivals</h2>\n            </div>\n            <button class=\"border-2 border-[#111111] px-8 py-3 font-bold uppercase text-xs hover:bg-[#111111] hover:text-white transition-all\" data-kid=\"91\">View Catalogue</button>\n        </div>\n\n        <div class=\"grid grid-cols-12 gap-8 h-[700px]\" data-kid=\"92\">\n            \n            <div class=\"col-span-12 md:col-span-7 relative brutalist-border overflow-hidden group\" data-kid=\"93\">\n                <img src=\"https://images.unsplash.com/photo-1635174815612-fd9636f70146?auto=format&w=1200&q=80&fit=crop\" alt=\"Harvester Promo\" class=\"w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110\" decoding=\"async\" loading=\"lazy\" data-kid=\"94\">\n                <div class=\"absolute inset-0 bg-gradient-to-t from-[#111111] via-[#111111]/20 to-transparent\" data-kid=\"95\"></div>\n                <div class=\"absolute top-8 left-8\" data-kid=\"96\">\n                    <span class=\"bg-[#FF5800] text-[#111111] px-6 py-2 font-bold uppercase text-sm brutalist-border shadow-[4px_4px_0px_0px_#111111]\" data-kid=\"97\">Mega Offer</span>\n                </div>\n                <div class=\"absolute bottom-12 left-12 right-12 text-white\" data-kid=\"98\">\n                    <h3 class=\"font-space text-5xl font-bold uppercase leading-none mb-6\" data-kid=\"99\">Harvester <br data-kid=\"100\"> Peak Season Sale</h3>\n                    <p class=\"text-gray-300 text-lg mb-8 max-w-lg leading-relaxed\" data-kid=\"101\">Upgrade your agricultural fleet with our premium 2024 models. Special financing available for bulk cooperative orders.</p>\n                    <div class=\"flex items-center gap-6\" data-kid=\"102\">\n                        <div class=\"flex gap-2\" data-kid=\"103\">\n                            <div class=\"bg-white/10 backdrop-blur-xl border border-white/20 p-4 text-center min-w-[90px]\" data-kid=\"104\">\n                                <span class=\"block text-3xl font-bold font-space\" data-kid=\"105\">14</span>\n                                <span class=\"text-[9px] uppercase font-bold tracking-widest text-gray-400\" data-kid=\"106\">Days Left</span>\n                            </div>\n                            <div class=\"bg-white/10 backdrop-blur-xl border border-white/20 p-4 text-center min-w-[90px]\" data-kid=\"107\">\n                                <span class=\"block text-3xl font-bold font-space\" data-kid=\"108\">09</span>\n                                <span class=\"text-[9px] uppercase font-bold tracking-widest text-gray-400\" data-kid=\"109\">Hours</span>\n                            </div>\n                        </div>\n                        <button class=\"bg-[#FF5800] text-[#111111] px-10 py-5 font-bold uppercase text-sm brutalist-border hover:bg-white transition-colors\" data-kid=\"110\">Claim Discount</button>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"col-span-12 md:col-span-5 grid grid-rows-2 gap-8\" data-kid=\"111\">\n                \n                <div class=\"bg-white brutalist-border p-8 flex group relative overflow-hidden\" data-kid=\"112\">\n                    <div class=\"z-10 w-1/2\" data-kid=\"113\">\n                        <span class=\"inline-block bg-[#111111] text-white text-[10px] font-bold uppercase px-3 py-1 mb-6\" data-kid=\"114\">New Arrival</span>\n                        <h4 class=\"font-space text-3xl font-bold uppercase tracking-tighter leading-none mb-2\" data-kid=\"115\">Pro-Series <br data-kid=\"116\"> Power Drill V2</h4>\n                        <p class=\"text-sm text-gray-400 font-bold uppercase mb-8\" data-kid=\"117\">SKU: IND-DRL-900</p>\n                        <button class=\"bg-[#111111] text-white px-6 py-3 font-bold uppercase text-[10px] brutalist-border hover:bg-[#FF5800] transition-colors\" data-kid=\"118\">\n                            Check Stock\n                        </button>\n                    </div>\n                    <div class=\"w-1/2 h-full flex items-center justify-center z-10 relative\" data-kid=\"119\">\n                        <img src=\"https://images.unsplash.com/photo-1572981779307-38b8cabb2407?auto=format&w=600&q=80&fit=crop\" alt=\"Power Drill\" class=\"w-full h-full object-contain group-hover:-rotate-12 transition-transform duration-500 scale-125\" decoding=\"async\" loading=\"lazy\" data-kid=\"120\">\n                    </div>\n                </div>\n\n                \n                <div class=\"bg-[#111111] brutalist-border p-8 flex items-center gap-8 group relative overflow-hidden\" data-kid=\"121\">\n                    <div class=\"z-10 w-1/2\" data-kid=\"122\">\n                        <span class=\"text-[#FF5800] text-[10px] font-bold uppercase tracking-[0.3em] mb-4 block\" data-kid=\"123\">Services</span>\n                        <h4 class=\"font-space text-3xl text-white font-bold uppercase leading-none mb-4\" data-kid=\"124\">Winter Care <br data-kid=\"125\"> Program</h4>\n                        <p class=\"text-xs text-gray-400 mb-6\" data-kid=\"126\">Preserve your investment with our certified maintenance packages.</p>\n                        <button class=\"border border-[#FF5800] text-[#FF5800] px-6 py-2.5 font-bold uppercase text-[10px] hover:bg-[#FF5800] hover:text-[#111111] transition-all\" data-kid=\"127\">Learn More</button>\n                    </div>\n                    <div class=\"w-1/2 h-full flex items-center justify-center z-10 opacity-30 group-hover:opacity-100 transition-opacity\" data-kid=\"128\">\n                        <i class=\"ti ti-settings text-[120px] text-[#91A3B0] animate-spin-slow\" data-kid=\"129\"></i>\n                    </div>\n                    <style data-kid=\"130\">\n                        .animate-spin-slow { animation: spin 10s linear infinite; }\n                        @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }\n                    </style>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section class=\"py-24 bg-[#111111] text-white overflow-hidden\" data-kid=\"131\">\n        <div class=\"px-8 md:px-12 mb-16 flex items-end justify-between\" data-kid=\"132\">\n            <div data-kid=\"133\">\n                <h2 class=\"font-space text-5xl font-bold uppercase tracking-tighter\" data-kid=\"134\">Best Selling <span class=\"text-[#FF5800]\" data-kid=\"135\">Hardware</span></h2>\n                <p class=\"text-gray-400 mt-4 max-w-lg\" data-kid=\"136\">Field-tested equipment verified by thousands of professionals across the subcontinent.</p>\n            </div>\n            <div class=\"flex gap-4\" data-kid=\"137\">\n                <button class=\"w-14 h-14 border-2 border-white/20 flex items-center justify-center hover:bg-white hover:text-[#111111] transition-all\" data-kid=\"138\"><i class=\"ti ti-arrow-left\" data-kid=\"139\"></i></button>\n                <button class=\"w-14 h-14 b